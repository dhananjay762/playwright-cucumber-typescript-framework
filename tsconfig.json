{
    "compilerOptions": {
        "target": "es2025",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "rootDir": "src",
        "outDir": "dist",
        "sourceMap": true
    },
    "ts-node": {
        "transpileOnly": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}